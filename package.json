{
  "name": "@onsetsoftware/automerge-patcher",
  "private": false,
  "repository": "https://github.com/onsetsoftware/automerge-patcher",
  "description": "Utility functions to apply and invert patches generated by Automerge document changes.",
  "version": "0.15.0-alpha.2",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "test": "vitest --watch",
    "bench": "vitest bench",
    "vitest.commandLine": "npm vitest run"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-externalize-deps": "^0.10.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@automerge/automerge": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/automerge-patcher.umd.cjs",
  "module": "./dist/automerge-patcher.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/automerge-patcher.js",
      "require": "./dist/automerge-patcher.umd.cjs"
    }
  },
  "types": "./dist/types/index.d.ts",
  "dependencies": {
    "is-plain-object": "^5.0.0"
  }
}
